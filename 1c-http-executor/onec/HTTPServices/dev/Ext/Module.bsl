#Область СлужебныеФункции

Функция СериализоватьЗначение(Значение)

	Если Значение = Неопределено Тогда
		Возврат Неопределено;
	КонецЕсли;

	ТипЗначения = ТипЗнч(Значение);

	Если ТипЗначения = Тип("Булево")
		ИЛИ ТипЗначения = Тип("Число")
		ИЛИ ТипЗначения = Тип("Строка") Тогда
		Возврат Значение;
	КонецЕсли;

	Если ТипЗначения = Тип("Дата") Тогда
		Возврат Формат(Значение, "ДФ=yyyy-MM-ddTHH:mm:ss");
	КонецЕсли;

	Если ТипЗначения = Тип("УникальныйИдентификатор") Тогда
		Возврат Строка(Значение);
	КонецЕсли;

	Если ТипЗначения = Тип("ТаблицаЗначений") Тогда
		Массив = Новый Массив;
		Для Каждого Стр Из Значение Цикл
			Стрк = Новый Структура;
			Для Каждого Кол Из Значение.Колонки Цикл
				Стрк.Вставить(Кол.Имя, СериализоватьЗначение(Стр[Кол.Имя]));
			КонецЦикла;
			Массив.Добавить(Стрк);
		КонецЦикла;
		Возврат Массив;
	КонецЕсли;

	Если ТипЗначения = Тип("Массив") Тогда
		Копия = Новый Массив;
		Для Каждого Эл Из Значение Цикл
			Копия.Добавить(СериализоватьЗначение(Эл));
		КонецЦикла;
		Возврат Копия;
	КонецЕсли;

	Если ТипЗначения = Тип("ФиксированныйМассив") Тогда
		Копия = Новый Массив;
		Для Каждого Эл Из Значение Цикл
			Копия.Добавить(СериализоватьЗначение(Эл));
		КонецЦикла;
		Возврат Копия;
	КонецЕсли;

	Если ТипЗначения = Тип("Структура") Тогда
		Копия = Новый Структура;
		Для Каждого Эл Из Значение Цикл
			Копия.Вставить(Эл.Ключ, СериализоватьЗначение(Эл.Значение));
		КонецЦикла;
		Возврат Копия;
	КонецЕсли;

	Если ТипЗначения = Тип("ФиксированнаяСтруктура") Тогда
		Копия = Новый Структура;
		Для Каждого Эл Из Значение Цикл
			Копия.Вставить(Эл.Ключ, СериализоватьЗначение(Эл.Значение));
		КонецЦикла;
		Возврат Копия;
	КонецЕсли;

	Если ТипЗначения = Тип("Соответствие") ИЛИ ТипЗначения = Тип("ФиксированноеСоответствие") Тогда
		Копия = Новый Структура;
		Сч = 0;
		Для Каждого Эл Из Значение Цикл
			КлючСтр = Строка(Эл.Ключ);
			Если ПустаяСтрока(КлючСтр) Тогда
				КлючСтр = "key_" + Формат(Сч, "ЧГ=");
			КонецЕсли;
			Попытка
				Копия.Вставить(КлючСтр, СериализоватьЗначение(Эл.Значение));
			Исключение
				Копия.Вставить("key_" + Формат(Сч, "ЧГ="), СериализоватьЗначение(Эл.Значение));
			КонецПопытки;
			Сч = Сч + 1;
		КонецЦикла;
		Возврат Копия;
	КонецЕсли;

	Если ТипЗначения = Тип("СписокЗначений") Тогда
		Массив = Новый Массив;
		Для Каждого Эл Из Значение Цикл
			Стрк = Новый Структура;
			Стрк.Вставить("Значение", СериализоватьЗначение(Эл.Значение));
			Стрк.Вставить("Представление", Эл.Представление);
			Стрк.Вставить("Пометка", Эл.Пометка);
			Массив.Добавить(Стрк);
		КонецЦикла;
		Возврат Массив;
	КонецЕсли;

	Если ТипЗначения = Тип("ДеревоЗначений") Тогда
		Возврат СериализоватьСтрокиДерева(Значение.Строки, Значение.Колонки);
	КонецЕсли;

	// Ссылки на объекты БД, перечисления и прочее — строковым представлением.
	Возврат Строка(Значение);

КонецФункции

Функция СериализоватьСтрокиДерева(Строки, Колонки)
	Массив = Новый Массив;
	Для Каждого Стр Из Строки Цикл
		Стрк = Новый Структура;
		Для Каждого Кол Из Колонки Цикл
			Стрк.Вставить(Кол.Имя, СериализоватьЗначение(Стр[Кол.Имя]));
		КонецЦикла;
		Стрк.Вставить("Строки", СериализоватьСтрокиДерева(Стр.Строки, Колонки));
		Массив.Добавить(Стрк);
	КонецЦикла;
	Возврат Массив;
КонецФункции

Функция ПрочитатьТелоЗапроса(Запрос)
	ТелоСтр = Запрос.ПолучитьТелоКакСтроку("UTF-8");
	Если ПустаяСтрока(ТелоСтр) Тогда
		Тело = Новый Структура;
		Тело.Вставить("code", "");
		Тело.Вставить("params", Новый Структура);
		Возврат Тело;
	КонецЕсли;
	Чтение = Новый ЧтениеJSON;
	Чтение.УстановитьСтроку(ТелоСтр);
	// Второй параметр = Ложь → JSON-объект читается в Структуру (а не в Соответствие).
	Данные = ПрочитатьJSON(Чтение, Ложь);
	Чтение.Закрыть();
	Если ТипЗнч(Данные) <> Тип("Структура") Тогда
		ВызватьИсключение "Ожидалась JSON-структура в теле запроса";
	КонецЕсли;
	Если НЕ Данные.Свойство("code") Тогда
		Данные.Вставить("code", "");
	КонецЕсли;
	Если НЕ Данные.Свойство("params") Тогда
		Данные.Вставить("params", Новый Структура);
	КонецЕсли;
	Возврат Данные;
КонецФункции

Функция СформироватьJSONОтвет(Данные, КодСостояния)
	Запись = Новый ЗаписьJSON;
	ПарЗаписи = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто, "  ", Истина);
	Запись.УстановитьСтроку(ПарЗаписи);
	// Даты у нас уже преобразованы в строки при сериализации,
	// поэтому НастройкиСериализацииJSON не задаём.
	ЗаписатьJSON(Запись, Данные);
	Текст = Запись.Закрыть();

	Ответ = Новый HTTPСервисОтвет(КодСостояния);
	Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки(Текст, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;
КонецФункции

Функция ОтветОшибкаОбработчика(Ошибка)
	Ответ = Новый HTTPСервисОтвет(500);
	Ответ.Заголовки.Вставить("Content-Type", "text/plain; charset=utf-8");
	Ответ.УстановитьТелоИзСтроки("HANDLER FATAL: " + Ошибка, "UTF-8", ИспользованиеByteOrderMark.НеИспользовать);
	Возврат Ответ;
КонецФункции

#КонецОбласти

// Главная процедура исполнения произвольного кода 1С,
// присланного в теле POST-запроса в JSON-формате:
// {
//   "code":   "<текст на встроенном языке>",
//   "params": { ... произвольная структура с входными параметрами ... }
// }
//
// Внутри переданного кода доступны:
//   * Параметры — структура с входными параметрами (см. поле "params").
//   * Результат — переменная, в которую код кладёт то, что хочет вернуть.
//                 Может быть Структурой, Массивом, ТаблицейЗначений
//                 (например полученной через Запрос.Выполнить().Выгрузить()),
//                 ДеревомЗначений, СпискомЗначений, примитивом и т.п.
//
// Сама конструкция Выполнить() обёрнута в Попытка/Исключение —
// любая ошибка при компиляции или выполнении кода возвращается клиенту в JSON
// (поле "error"), а не приводит к 500-й от веб-сервера.
Функция ВыполнитьПроизвольныйКод(Запрос)

	Результат = Неопределено;
	Параметры = Новый Структура;

	Ответ = Новый Структура;
	Ответ.Вставить("ok", Ложь);
	Ответ.Вставить("result", Неопределено);
	Ответ.Вставить("error", "");
	Ответ.Вставить("errorInfo", Неопределено);
	// Тайминг: executionMs — сколько отработал Выполнить(Код); serializationMs —
	// сколько ушло на конвертацию Результата в JSON-структуру.
	// Поля присутствуют ВСЕГДА, в том числе при ошибках на ранних стадиях
	// (parse, пустой код) — там значения остаются 0.
	Ответ.Вставить("executionMs", 0);
	Ответ.Вставить("serializationMs", 0);

	Попытка
		ТелоЗапроса = ПрочитатьТелоЗапроса(Запрос);
	Исключение
		Ответ.error = "Не удалось разобрать тело запроса: "
			+ ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
		Возврат СформироватьJSONОтвет(Ответ, 400);
	КонецПопытки;

	Код = ТелоЗапроса.code;
	Если ТелоЗапроса.Свойство("params") И ТипЗнч(ТелоЗапроса.params) = Тип("Структура") Тогда
		Параметры = ТелоЗапроса.params;
	КонецЕсли;

	Если ПустаяСтрока(Код) Тогда
		Ответ.error = "В теле запроса не передан исполняемый код (поле 'code')";
		Возврат СформироватьJSONОтвет(Ответ, 400);
	КонецЕсли;

	НачалоМс = ТекущаяУниверсальнаяДатаВМиллисекундах();
	Попытка
		Выполнить(Код);
		Ответ.executionMs = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоМс;
		Ответ.ok = Истина;
		НачалоСерМс = ТекущаяУниверсальнаяДатаВМиллисекундах();
		Ответ.result = СериализоватьЗначение(Результат);
		Ответ.serializationMs = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоСерМс;
	Исключение
		Ответ.executionMs = ТекущаяУниверсальнаяДатаВМиллисекундах() - НачалоМс;
		ИО = ИнформацияОбОшибке();
		Ответ.error = ПодробноеПредставлениеОшибки(ИО);
		ИнфОшибки = Новый Структура;
		ИнфОшибки.Вставить("description", КраткоеПредставлениеОшибки(ИО));
		ИнфОшибки.Вставить("detailed",    ПодробноеПредставлениеОшибки(ИО));
		Ответ.errorInfo = ИнфОшибки;
	КонецПопытки;

	Возврат СформироватьJSONОтвет(Ответ, 200);

КонецФункции

Функция readPOST(Запрос)
	Попытка
		Возврат ВыполнитьПроизвольныйКод(Запрос);
	Исключение
		Возврат ОтветОшибкаОбработчика(ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
КонецФункции

Функция writePOST(Запрос)
	Попытка
		Возврат ВыполнитьПроизвольныйКод(Запрос);
	Исключение
		Возврат ОтветОшибкаОбработчика(ПодробноеПредставлениеОшибки(ИнформацияОбОшибке()));
	КонецПопытки;
КонецФункции
